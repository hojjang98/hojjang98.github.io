    <item>
      <title>Day 50: 실무 사례 #10 - 7.7 DDoS 대란 (2009)</title>
      <link>http://localhost:1313/cyber_law_study/05_%EC%8B%A4%EB%AC%B4%EC%82%AC%EB%A1%80/02_%ED%95%B4%ED%82%B9%EC%B9%A8%ED%95%B4/day50_%ED%95%B4%ED%82%B9%EC%B9%A8%ED%95%B4%EC%82%AC%EB%A1%803_ddos%EB%8C%80%EB%9E%80/</link>
