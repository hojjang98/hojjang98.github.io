    <item>
      <title>Day 52: 실무 사례 #12 - 청와대 해킹 사건 (2013)</title>
      <link>http://localhost:1313/cyber_law_study/05_%EC%8B%A4%EB%AC%B4%EC%82%AC%EB%A1%80/02_%ED%95%B4%ED%82%B9%EC%B9%A8%ED%95%B4/day52_%ED%95%B4%ED%82%B9%EC%B9%A8%ED%95%B4%EC%82%AC%EB%A1%804_%EC%B2%AD%EC%99%80%EB%8C%80%ED%95%B4%ED%82%B9/</link>
